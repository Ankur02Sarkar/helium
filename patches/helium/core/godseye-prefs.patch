+// Watches each tab for page-load completion and injects a keyword detection
+// script when God's Eye is active.
+class GodsEyeTabHelper
+    : public content::WebContentsObserver,
+      public content::WebContentsUserData<GodsEyeTabHelper> {
+ public:
+  ~GodsEyeTabHelper() override;
+
+  // content::WebContentsObserver:
+  void DidFinishLoad(content::RenderFrameHost* rfh,
+                     const GURL& validated_url) override;
+
+ private:
+  friend class content::WebContentsUserData<GodsEyeTabHelper>;
+  explicit GodsEyeTabHelper(content::WebContents* web_contents);
+
+  WEB_CONTENTS_USER_DATA_KEY_DECL();
+};
