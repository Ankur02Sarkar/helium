+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#ifndef CHROME_BROWSER_GODSEYE_GODSEYE_CONFIG_H_
+#define CHROME_BROWSER_GODSEYE_GODSEYE_CONFIG_H_
+
+#include <cstdint>
+#include <string>
+#include <vector>
+
+#include "base/files/file_path.h"
+#include "base/memory/raw_ptr.h"
+#include "base/time/time.h"
+#include "components/prefs/pref_service.h"
+
+namespace godseye {
+
+// Salt embedded in the binary for HMAC key derivation.
+// Combined with the profile path hash to produce a per-installation key.
+inline constexpr char kGodsEyeHmacSalt[] =
+    "helium-godseye-v1-tamper-protection-2025";
+
+// Manages persistent God's Eye configuration.
+// Writes an HMAC-SHA256 signed JSON file alongside PrefService entries so
+// that simply editing the Preferences JSON file does not allow bypassing the
+// expiry lock.
+//
+// Fail-safe: if the HMAC file is missing or invalid, the config is treated
+// as "locked" (blocking remains active) until a valid file is present.
+class GodsEyeConfig {
+ public:
+  explicit GodsEyeConfig(PrefService* prefs,
+                         const base::FilePath& profile_path);
+  ~GodsEyeConfig();
+
+  // Returns true if God's Eye is active AND the expiry has not been reached
+  // according to the stored UTC timestamp. Uses a remote time source
+  // (timeapi.io) when available; falls back to base::Time::Now() only when
+  // the network call has previously succeeded (cached offset) to resist
+  // system-clock manipulation.
+  bool IsEnabled() const;
+
+  // Returns true if the expiry time has NOT yet been reached (i.e. the list
+  // is still locked and cannot be edited/deleted).
+  bool IsLocked() const;
+
+  // Seconds remaining until unlock. Returns 0 if already expired or disabled.
+  int64_t SecondsRemaining() const;
+
+  // Returns the list of blocked URL hostnames (e.g. "example.com").
+  std::vector<std::string> GetBlockedUrls() const;
+
+  // Returns the list of blocked keywords (case-insensitive matching).
+  std::vector<std::string> GetBlockedKeywords() const;
+
+  // Returns the stored expiry timestamp (seconds since Unix epoch, UTC).
+  int64_t GetExpirySeconds() const;
+
+  // Activate God's Eye. Writes the HMAC-signed config file and updates prefs.
+  // |expiry_utc_seconds|: absolute Unix timestamp (UTC) when blocking expires.
+  // |urls|: list of hostname patterns to block.
+  // |keywords|: list of keywords to block.
+  void Activate(int64_t expiry_utc_seconds,
+                const std::vector<std::string>& urls,
+                const std::vector<std::string>& keywords);
+
+  // Add a new URL without modifying the expiry (always allowed).
+  void AddUrl(const std::string& url);
+
+  // Add a new keyword without modifying the expiry (always allowed).
+  void AddKeyword(const std::string& keyword);
+
+  // Remove URL — only succeeds when !IsLocked().
+  bool RemoveUrl(const std::string& url);
+
+  // Remove keyword — only succeeds when !IsLocked().
+  bool RemoveKeyword(const std::string& keyword);
+
+ private:
+  // Derives the HMAC key from the salt + profile path hash.
+  std::string DeriveHmacKey() const;
+
+  // Writes the current prefs state to the signed config file.
+  void PersistToFile();
+
+  // Validates the HMAC of the config file. Returns false if tampered.
+  bool ValidateFile() const;
+
+  raw_ptr<PrefService> prefs_;
+  base::FilePath profile_path_;
+  base::FilePath config_file_path_;
+};
+
+}  // namespace godseye
+
+#endif  // CHROME_BROWSER_GODSEYE_GODSEYE_CONFIG_H_
