+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/godseye/godseye_tab_helper.h"
+
+#include <string>
+#include <vector>
+
+#include "base/functional/callback.h"
+#include "base/json/json_writer.h"
+#include "base/strings/strcat.h"
+#include "base/strings/string_util.h"
+#include "base/strings/utf_string_conversions.h"
+#include "base/values.h"
+#include "chrome/browser/godseye/godseye_config.h"
+#include "chrome/browser/profiles/profile.h"
+#include "content/public/browser/navigation_handle.h"
+#include "content/public/browser/render_frame_host.h"
+#include "content/public/browser/web_contents.h"
+#include "url/gurl.h"
+
+WEB_CONTENTS_USER_DATA_KEY_IMPL(GodsEyeTabHelper);
+
+GodsEyeTabHelper::GodsEyeTabHelper(content::WebContents* web_contents)
+    : content::WebContentsObserver(web_contents),
+      content::WebContentsUserData<GodsEyeTabHelper>(*web_contents) {}
+
+GodsEyeTabHelper::~GodsEyeTabHelper() = default;
+
+void GodsEyeTabHelper::DidFinishLoad(content::RenderFrameHost* rfh,
+                                      const GURL& validated_url) {
+  // Only inspect main frames.
+  if (!rfh->IsInPrimaryMainFrame()) return;
+
+  // Never intercept internal Helium/Chrome pages.
+  if (validated_url.SchemeIs("chrome") ||
+      validated_url.SchemeIs("helium") ||
+      validated_url.SchemeIs("about") ||
+      validated_url.SchemeIs("data")) {
+    return;
+  }
+
+  content::WebContents* wc = web_contents();
+  if (!wc) return;
+
+  Profile* profile = Profile::FromBrowserContext(wc->GetBrowserContext());
+  if (!profile || profile->IsOffTheRecord()) return;
+
+  godseye::GodsEyeConfig config(profile->GetPrefs(),
+                                 profile->GetPath());
+  if (!config.IsEnabled()) return;
+
+  std::vector<std::string> keywords = config.GetBlockedKeywords();
+  if (keywords.empty()) return;
+
+  // Build a JSON array of lowercase keywords to pass into the script.
+  base::Value::List kw_list;
+  for (const auto& kw : keywords) {
+    kw_list.Append(base::ToLowerASCII(kw));
+  }
+  std::string kw_json;
+  base::JSONWriter::Write(base::Value(std::move(kw_list)), &kw_json);
+
+  // Build the injection script.
+  // It checks document.body.innerText (lowercased) for each keyword.
+  // On match it navigates to chrome://restricted-page.
+  std::string script = base::StrCat({
+      "(function() {",
+      "  var keywords = ", kw_json, ";",
+      "  var text = document.body ? document.body.innerText.toLowerCase() : '';",
+      "  for (var i = 0; i < keywords.length; i++) {",
+      "    if (text.indexOf(keywords[i]) !== -1) {",
+      "      window.location = 'chrome://restricted-page?type=keyword&value='"
+      "          + encodeURIComponent(keywords[i]);",
+      "      return;",
+      "    }",
+      "  }",
+      "})();"
+  });
+
+  // Use ExecuteJavaScript with a no-op callback for production use.
+  // This is safe because the script only reads innerText and potentially
+  // performs a navigation — no privileged operations.
+  rfh->ExecuteJavaScript(base::UTF8ToUTF16(script), base::DoNothing());
+}
