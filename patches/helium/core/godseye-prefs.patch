+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/godseye/godseye_config.h"
+
+#include <algorithm>
+#include <cstdint>
+#include <string>
+#include <vector>
+
+#include "base/base64.h"
+#include "base/files/file_path.h"
+#include "base/files/file_util.h"
+#include "base/hash/sha1.h"
+#include "base/json/json_reader.h"
+#include "base/json/json_writer.h"
+#include "base/logging.h"
+#include "base/strings/string_number_conversions.h"
+#include "base/strings/string_util.h"
+#include "base/time/time.h"
+#include "base/values.h"
+#include "components/helium_services/pref_names.h"
+#include "components/prefs/pref_service.h"
+#include "crypto/hmac.h"
+
+namespace godseye {
+
+namespace {
+
+// Produce a stable string representation of the config payload for HMAC.
+std::string BuildPayload(int64_t expiry,
+                         const std::vector<std::string>& urls,
+                         const std::vector<std::string>& keywords) {
+  // Canonical form: expiry|url1,url2,...|kw1,kw2,...
+  std::string payload;
+  payload += base::NumberToString(expiry);
+  payload += "|";
+  for (size_t i = 0; i < urls.size(); ++i) {
+    if (i) payload += ",";
+    payload += urls[i];
+  }
+  payload += "|";
+  for (size_t i = 0; i < keywords.size(); ++i) {
+    if (i) payload += ",";
+    payload += keywords[i];
+  }
+  return payload;
+}
+
+int64_t NowUtcSeconds() {
+  return (base::Time::Now() - base::Time::UnixEpoch()).InSeconds();
+}
+
+}  // namespace
+
+GodsEyeConfig::GodsEyeConfig(PrefService* prefs,
+                               const base::FilePath& profile_path)
+    : prefs_(prefs),
+      profile_path_(profile_path),
+      config_file_path_(profile_path.AppendASCII("godseye")
+                                    .AppendASCII("config.json")) {}
+
+GodsEyeConfig::~GodsEyeConfig() = default;
+
+std::string GodsEyeConfig::DeriveHmacKey() const {
+  // Key = SHA1( salt + profile_path_utf8 )
+  // This ties the HMAC to the specific installation without requiring
+  // any network call or OS-level machine ID (which may not be available).
+  std::string path_str = profile_path_.AsUTF8Unsafe();
+  std::string combined = std::string(kGodsEyeHmacSalt) + path_str;
+  auto digest = base::SHA1HashString(combined);
+  return std::string(reinterpret_cast<const char*>(digest.data()),
+                     digest.size());
+}
+
+void GodsEyeConfig::PersistToFile() {
+  int64_t expiry =
+      static_cast<int64_t>(prefs_->GetDouble(prefs::kHeliumGodsEyeExpirySeconds));
+  std::vector<std::string> urls = GetBlockedUrls();
+  std::vector<std::string> keywords = GetBlockedKeywords();
+
+  std::string payload = BuildPayload(expiry, urls, keywords);
+  std::string key = DeriveHmacKey();
+
+  crypto::HMAC hmac(crypto::HMAC::SHA256);
+  if (!hmac.Init(key)) {
+    LOG(ERROR) << "GodsEye: HMAC init failed";
+    return;
+  }
+
+  std::vector<uint8_t> mac(hmac.DigestLength());
+  if (!hmac.Sign(payload, mac.data(), mac.size())) {
+    LOG(ERROR) << "GodsEye: HMAC sign failed";
+    return;
+  }
+
+  std::string mac_hex = base::HexEncode(mac.data(), mac.size());
+
+  // Build JSON
+  base::Value::Dict root;
+  root.Set("expiry_utc_seconds", base::Value(static_cast<double>(expiry)));
+  root.Set("hmac", mac_hex);
+
+  base::Value::List url_list;
+  for (const auto& u : urls) url_list.Append(u);
+  root.Set("blocked_urls", std::move(url_list));
+
+  base::Value::List kw_list;
+  for (const auto& k : keywords) kw_list.Append(k);
+  root.Set("blocked_keywords", std::move(kw_list));
+
+  std::string json_str;
+  base::JSONWriter::Write(base::Value(std::move(root)), &json_str);
+
+  // Ensure directory exists
+  base::FilePath dir = config_file_path_.DirName();
+  base::CreateDirectory(dir);
+
+  if (!base::WriteFile(config_file_path_, json_str)) {
+    LOG(ERROR) << "GodsEye: Failed to write config file";
+  }
+}
+
+bool GodsEyeConfig::ValidateFile() const {
+  std::string json_str;
+  if (!base::ReadFileToString(config_file_path_, &json_str)) {
+    // File doesn't exist — not necessarily tampered, just not set up.
+    return false;
+  }
+
+  auto result = base::JSONReader::ReadAndReturnValueWithError(json_str);
+  if (!result.has_value() || !result->is_dict()) {
+    LOG(WARNING) << "GodsEye: Config file is not valid JSON";
+    return false;
+  }
+
+  const base::Value::Dict& dict = result->GetDict();
+  const std::string* stored_mac = dict.FindString("hmac");
+  if (!stored_mac) return false;
+
+  int64_t expiry = static_cast<int64_t>(
+      dict.FindDouble("expiry_utc_seconds").value_or(0.0));
+
+  std::vector<std::string> urls, keywords;
+  if (const auto* url_list = dict.FindList("blocked_urls")) {
+    for (const auto& v : *url_list) {
+      if (v.is_string()) urls.push_back(v.GetString());
+    }
+  }
+  if (const auto* kw_list = dict.FindList("blocked_keywords")) {
+    for (const auto& v : *kw_list) {
+      if (v.is_string()) keywords.push_back(v.GetString());
+    }
+  }
+
+  std::string payload = BuildPayload(expiry, urls, keywords);
+  std::string key = DeriveHmacKey();
+
+  crypto::HMAC hmac(crypto::HMAC::SHA256);
+  if (!hmac.Init(key)) return false;
+
+  // Decode stored hex MAC
+  std::vector<uint8_t> stored_bytes;
+  if (!base::HexStringToBytes(*stored_mac, &stored_bytes)) return false;
+
+  return hmac.Verify(payload, base::span<const uint8_t>(stored_bytes));
+}
+
+bool GodsEyeConfig::IsEnabled() const {
+  return prefs_->GetBoolean(prefs::kHeliumGodsEyeEnabled);
+}
+
+bool GodsEyeConfig::IsLocked() const {
+  if (!IsEnabled()) return false;
+  return SecondsRemaining() > 0;
+}
+
+int64_t GodsEyeConfig::SecondsRemaining() const {
+  int64_t expiry =
+      static_cast<int64_t>(prefs_->GetDouble(prefs::kHeliumGodsEyeExpirySeconds));
+  if (expiry <= 0) return 0;
+  int64_t now = NowUtcSeconds();
+  int64_t remaining = expiry - now;
+  return remaining > 0 ? remaining : 0;
+}
+
+std::vector<std::string> GodsEyeConfig::GetBlockedUrls() const {
+  std::vector<std::string> result;
+  const base::Value::List& list =
+      prefs_->GetList(prefs::kHeliumGodsEyeBlockedUrls);
+  for (const auto& v : list) {
+    if (v.is_string()) result.push_back(v.GetString());
+  }
+  return result;
+}
+
+std::vector<std::string> GodsEyeConfig::GetBlockedKeywords() const {
+  std::vector<std::string> result;
+  const base::Value::List& list =
+      prefs_->GetList(prefs::kHeliumGodsEyeBlockedKeywords);
+  for (const auto& v : list) {
+    if (v.is_string()) result.push_back(v.GetString());
+  }
+  return result;
+}
+
+int64_t GodsEyeConfig::GetExpirySeconds() const {
+  return static_cast<int64_t>(
+      prefs_->GetDouble(prefs::kHeliumGodsEyeExpirySeconds));
+}
+
+void GodsEyeConfig::Activate(int64_t expiry_utc_seconds,
+                               const std::vector<std::string>& urls,
+                               const std::vector<std::string>& keywords) {
+  prefs_->SetBoolean(prefs::kHeliumGodsEyeEnabled, true);
+  prefs_->SetDouble(prefs::kHeliumGodsEyeExpirySeconds,
+                    static_cast<double>(expiry_utc_seconds));
+
+  base::Value::List url_list;
+  for (const auto& u : urls) url_list.Append(u);
+  prefs_->SetList(prefs::kHeliumGodsEyeBlockedUrls, std::move(url_list));
+
+  base::Value::List kw_list;
+  for (const auto& k : keywords) kw_list.Append(k);
+  prefs_->SetList(prefs::kHeliumGodsEyeBlockedKeywords, std::move(kw_list));
+
+  PersistToFile();
+}
+
+void GodsEyeConfig::AddUrl(const std::string& url) {
+  base::Value::List list =
+      prefs_->GetList(prefs::kHeliumGodsEyeBlockedUrls).Clone();
+  list.Append(url);
+  prefs_->SetList(prefs::kHeliumGodsEyeBlockedUrls, std::move(list));
+  PersistToFile();
+}
+
+void GodsEyeConfig::AddKeyword(const std::string& keyword) {
+  base::Value::List list =
+      prefs_->GetList(prefs::kHeliumGodsEyeBlockedKeywords).Clone();
+  list.Append(keyword);
+  prefs_->SetList(prefs::kHeliumGodsEyeBlockedKeywords, std::move(list));
+  PersistToFile();
+}
+
+bool GodsEyeConfig::RemoveUrl(const std::string& url) {
+  if (IsLocked()) return false;
+  base::Value::List list =
+      prefs_->GetList(prefs::kHeliumGodsEyeBlockedUrls).Clone();
+  list.EraseIf([&url](const base::Value& v) {
+    return v.is_string() && v.GetString() == url;
+  });
+  prefs_->SetList(prefs::kHeliumGodsEyeBlockedUrls, std::move(list));
+  PersistToFile();
+  return true;
+}
+
+bool GodsEyeConfig::RemoveKeyword(const std::string& keyword) {
+  if (IsLocked()) return false;
+  base::Value::List list =
+      prefs_->GetList(prefs::kHeliumGodsEyeBlockedKeywords).Clone();
+  list.EraseIf([&keyword](const base::Value& v) {
+    return v.is_string() && v.GetString() == keyword;
+  });
+  prefs_->SetList(prefs::kHeliumGodsEyeBlockedKeywords, std::move(list));
+  PersistToFile();
+  return true;
+}
+
+}  // namespace godseye
