+#ifndef CHROME_BROWSER_UI_WEBUI_GODSEYE_GODSEYE_HANDLER_H_
+#define CHROME_BROWSER_UI_WEBUI_GODSEYE_GODSEYE_HANDLER_H_
+
+#include <memory>
+
+#include "base/memory/raw_ptr.h"
+#include "base/values.h"
+#include "content/public/browser/web_ui_message_handler.h"
+
+class Profile;
+
+namespace godseye {
+class GodsEyeConfig;
+}
+
+class GodsEyeHandler : public content::WebUIMessageHandler {
+ public:
+  explicit GodsEyeHandler(Profile* profile);
+  GodsEyeHandler(const GodsEyeHandler&) = delete;
+  GodsEyeHandler& operator=(const GodsEyeHandler&) = delete;
+  ~GodsEyeHandler() override;
+
+  void RegisterMessages() override;
+
+ private:
+  // Returns current state: {isEnabled, isLocked, blockedUrls, blockedKeywords,
+  //                          expirySeconds, secondsRemaining}
+  void HandleGetState(const base::Value::List& args);
+
+  // Activates God's Eye: args = [callbackId, expiryUtcSeconds, urls[], keywords[]]
+  void HandleActivate(const base::Value::List& args);
+
+  // Add a URL (always allowed): args = [callbackId, url]
+  void HandleAddUrl(const base::Value::List& args);
+
+  // Add a keyword (always allowed): args = [callbackId, keyword]
+  void HandleAddKeyword(const base::Value::List& args);
+
+  // Remove URL (only when unlocked): args = [callbackId, url]
+  void HandleRemoveUrl(const base::Value::List& args);
+
+  // Remove keyword (only when unlocked): args = [callbackId, keyword]
+  void HandleRemoveKeyword(const base::Value::List& args);
+
+  raw_ptr<Profile> profile_;
+  std::unique_ptr<godseye::GodsEyeConfig> config_;
+};
