+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+import {sendWithPromise} from 'chrome://resources/js/cr.js';
+
+interface GodsEyeState {
+  isEnabled: boolean;
+  isLocked: boolean;
+  expirySeconds: number;
+  secondsRemaining: number;
+  blockedUrls: string[];
+  blockedKeywords: string[];
+}
+
+class HeliumGodsEyeApp extends HTMLElement {
+  private state: GodsEyeState | null = null;
+  private urlInput: HTMLInputElement | null = null;
+  private keywordInput: HTMLInputElement | null = null;
+  private expiryInput: HTMLInputElement | null = null;
+  private countdownInterval: number | null = null;
+  private pendingUrls: string[] = [];
+  private pendingKeywords: string[] = [];
+
+  connectedCallback() {
+    this.render();
+    this.loadState();
+  }
+
+  disconnectedCallback() {
+    if (this.countdownInterval !== null) {
+      clearInterval(this.countdownInterval);
+    }
+  }
+
+  private async loadState() {
+    try {
+      this.state = await sendWithPromise<GodsEyeState>('getGodsEyeState');
+      this.render();
+      if (this.state.isLocked) {
+        this.startCountdown();
+      }
+    } catch (e) {
+      console.error('Failed to load God\'s Eye state', e);
+    }
+  }
+
+  private startCountdown() {
+    if (this.countdownInterval !== null) clearInterval(this.countdownInterval);
+    this.countdownInterval = window.setInterval(() => {
+      if (this.state) {
+        this.state.secondsRemaining = Math.max(0, this.state.secondsRemaining - 1);
+        this.updateCountdownDisplay();
+        if (this.state.secondsRemaining === 0) {
+          clearInterval(this.countdownInterval!);
+          this.loadState();
+        }
+      }
+    }, 1000);
+  }
+
+  private formatCountdown(secs: number): string {
+    const d = Math.floor(secs / 86400);
+    const h = Math.floor((secs % 86400) / 3600);
+    const m = Math.floor((secs % 3600) / 60);
+    const s = secs % 60;
+    const parts = [];
+    if (d > 0) parts.push(`${d}d`);
+    if (h > 0 || d > 0) parts.push(`${h}h`);
+    if (m > 0 || h > 0 || d > 0) parts.push(`${m}m`);
+    parts.push(`${s}s`);
+    return parts.join(' ');
+  }
+
+  private updateCountdownDisplay() {
+    const el = this.querySelector('#countdown-display');
+    if (el && this.state) {
+      el.textContent = this.formatCountdown(this.state.secondsRemaining);
+    }
+  }
+
+  private async fetchCurrentUtcSeconds(): Promise<number> {
+    // Use timeapi.io for authoritative UTC time (not system clock).
+    try {
+      const resp = await fetch(
+          'https://timeapi.io/api/time/current/zone?timeZone=UTC',
+          {cache: 'no-store'});
+      if (resp.ok) {
+        const json = await resp.json();
+        // dateTime is ISO8601 in UTC
+        return Math.floor(new Date(json.dateTime + 'Z').getTime() / 1000);
+      }
+    } catch (_) {}
+    // Fallback to local time only if network unavailable
+    return Math.floor(Date.now() / 1000);
+  }
+
+  private async handleActivate() {
+    const expiryInput = this.expiryInput;
+    if (!expiryInput || !expiryInput.value) {
+      alert('Please select an expiry date and time.');
+      return;
+    }
+
+    // Get authoritative current UTC time from timeapi.io
+    const nowUtc = await this.fetchCurrentUtcSeconds();
+    // Convert local datetime-local value to UTC seconds
+    const localDate = new Date(expiryInput.value);
+    const expiryUtcSeconds = Math.floor(localDate.getTime() / 1000);
+
+    if (expiryUtcSeconds <= nowUtc) {
+      alert('Expiry time must be in the future.');
+      return;
+    }
+
+    const allUrls = [
+      ...(this.state?.blockedUrls || []),
+      ...this.pendingUrls,
+    ];
+    const allKeywords = [
+      ...(this.state?.blockedKeywords || []),
+      ...this.pendingKeywords,
+    ];
+
+    if (allUrls.length === 0 && allKeywords.length === 0) {
+      alert('Add at least one URL or keyword to block.');
+      return;
+    }
+
+    await sendWithPromise('activateGodsEye', expiryUtcSeconds, allUrls, allKeywords);
+    this.pendingUrls = [];
+    this.pendingKeywords = [];
+    await this.loadState();
+  }
+
+  private async handleAddUrl(url: string) {
+    if (!url.trim()) return;
+    const clean = url.trim().toLowerCase().replace(/^https?:\/\//, '').split('/')[0];
+    if (!clean) return;
+
+    if (this.state?.isEnabled) {
+      // Already activated — add directly via handler
+      await sendWithPromise('godsEyeAddUrl', clean);
+      await this.loadState();
+    } else {
+      // Pre-activation: accumulate locally
+      if (!this.pendingUrls.includes(clean)) {
+        this.pendingUrls.push(clean);
+      }
+      this.render();
+    }
+    if (this.urlInput) this.urlInput.value = '';
+  }
+
+  private async handleAddKeyword(keyword: string) {
+    if (!keyword.trim()) return;
+    const clean = keyword.trim().toLowerCase();
+    if (!clean) return;
+
+    if (this.state?.isEnabled) {
+      await sendWithPromise('godsEyeAddKeyword', clean);
+      await this.loadState();
+    } else {
+      if (!this.pendingKeywords.includes(clean)) {
+        this.pendingKeywords.push(clean);
+      }
+      this.render();
+    }
+    if (this.keywordInput) this.keywordInput.value = '';
+  }
+
+  private async handleRemoveUrl(url: string) {
+    await sendWithPromise('godsEyeRemoveUrl', url);
+    await this.loadState();
+  }
+
+  private async handleRemoveKeyword(keyword: string) {
+    await sendWithPromise('godsEyeRemoveKeyword', keyword);
+    await this.loadState();
+  }
+
+  private removePendingUrl(url: string) {
+    this.pendingUrls = this.pendingUrls.filter(u => u !== url);
+    this.render();
+  }
+
+  private removePendingKeyword(kw: string) {
+    this.pendingKeywords = this.pendingKeywords.filter(k => k !== kw);
+    this.render();
+  }
+
+  private render() {
+    const s = this.state;
+    const isActive = s?.isEnabled ?? false;
+    const isLocked = s?.isLocked ?? false;
+
+    const allUrls = [...(s?.blockedUrls || []), ...(!isActive ? this.pendingUrls : [])];
+    const allKeywords = [...(s?.blockedKeywords || []), ...(!isActive ? this.pendingKeywords : [])];
+
+    let countdown = '';
+    if (isLocked && s) {
+      countdown = this.formatCountdown(s.secondsRemaining);
+    }
+
+    this.innerHTML = `
+      <div class="header">
+        <span class="eye-icon">&#x1F441;</span>
+        <h1>God's Eye</h1>
+        <p>Focus blocker — lock URLs and keywords until a chosen time</p>
+      </div>
+
+      ${isActive ? `
+        <div class="status-banner ${isLocked ? 'active' : 'inactive'}">
+          <div class="status-dot"></div>
+          ${isLocked
+            ? `LOCKED &mdash; cannot edit existing entries`
+            : `UNLOCKED &mdash; expiry has passed, you may now edit entries`}
+        </div>
+        ${isLocked ? `
+          <div class="card" style="text-align:center;padding:16px 20px;">
+            <div class="card-title">Time Remaining</div>
+            <div class="countdown" id="countdown-display">${countdown}</div>
+          </div>
+        ` : ''}
+      ` : `
+        <div class="status-banner inactive">
+          <div class="status-dot"></div>
+          God's Eye is not active
+        </div>
+      `}
+
+      <!-- URL Blocking Card -->
+      <div class="card">
+        <div class="card-title">Blocked Domains</div>
+        <div class="input-row">
+          <input id="url-input" type="text" placeholder="example.com or sub.example.com" />
+          <button id="add-url-btn" class="btn btn-primary">Add</button>
+        </div>
+        <div class="tag-list">
+          ${allUrls.length === 0
+            ? '<span class="empty-hint">No domains blocked yet</span>'
+            : allUrls.map(u => {
+                const isPending = !isActive && this.pendingUrls.includes(u);
+                const canRemove = !isLocked || isPending;
+                return `
+                  <span class="tag">
+                    ${this.escapeHtml(u)}
+                    <button class="remove-btn" data-url="${this.escapeHtml(u)}"
+                      data-pending="${isPending}"
+                      ${canRemove ? '' : 'disabled'}
+                      title="${isLocked && !isPending ? 'Locked until expiry' : 'Remove'}">
+                      &times;
+                    </button>
+                  </span>`;
+              }).join('')}
+        </div>
+      </div>
+
+      <!-- Keyword Blocking Card -->
+      <div class="card">
+        <div class="card-title">Blocked Keywords</div>
+        <div class="input-row">
+          <input id="keyword-input" type="text" placeholder="keyword, phrase..." />
+          <button id="add-keyword-btn" class="btn btn-primary">Add</button>
+        </div>
+        <div class="tag-list">
+          ${allKeywords.length === 0
+            ? '<span class="empty-hint">No keywords blocked yet</span>'
+            : allKeywords.map(k => {
+                const isPending = !isActive && this.pendingKeywords.includes(k);
+                const canRemove = !isLocked || isPending;
+                return `
+                  <span class="tag">
+                    ${this.escapeHtml(k)}
+                    <button class="remove-btn" data-keyword="${this.escapeHtml(k)}"
+                      data-pending="${isPending}"
+                      ${canRemove ? '' : 'disabled'}
+                      title="${isLocked && !isPending ? 'Locked until expiry' : 'Remove'}">
+                      &times;
+                    </button>
+                  </span>`;
+              }).join('')}
+        </div>
+      </div>
+
+      ${!isActive ? `
+        <!-- Expiry Picker -->
+        <div class="card expiry-section">
+          <div class="card-title">Lock Until</div>
+          <label>Choose the date and time when blocking expires:</label>
+          <input id="expiry-input" type="datetime-local" />
+        </div>
+        <button id="activate-btn" class="activate-btn">
+          Activate God's Eye
+        </button>
+      ` : ''}
+    `;
+
+    // Wire up event listeners after render
+    this.urlInput = this.querySelector('#url-input');
+    this.keywordInput = this.querySelector('#keyword-input');
+    this.expiryInput = this.querySelector('#expiry-input');
+
+    this.querySelector('#add-url-btn')?.addEventListener('click', () => {
+      this.handleAddUrl(this.urlInput?.value || '');
+    });
+    this.urlInput?.addEventListener('keydown', (e: Event) => {
+      if ((e as KeyboardEvent).key === 'Enter') this.handleAddUrl(this.urlInput?.value || '');
+    });
+
+    this.querySelector('#add-keyword-btn')?.addEventListener('click', () => {
+      this.handleAddKeyword(this.keywordInput?.value || '');
+    });
+    this.keywordInput?.addEventListener('keydown', (e: Event) => {
+      if ((e as KeyboardEvent).key === 'Enter') this.handleAddKeyword(this.keywordInput?.value || '');
+    });
+
+    this.querySelector('#activate-btn')?.addEventListener('click', () => {
+      this.handleActivate();
+    });
+
+    // Remove buttons for URLs
+    this.querySelectorAll('[data-url]').forEach(btn => {
+      btn.addEventListener('click', () => {
+        const url = (btn as HTMLElement).dataset['url'] || '';
+        const isPending = (btn as HTMLElement).dataset['pending'] === 'true';
+        if (isPending) {
+          this.removePendingUrl(url);
+        } else {
+          this.handleRemoveUrl(url);
+        }
+      });
+    });
+
+    // Remove buttons for keywords
+    this.querySelectorAll('[data-keyword]').forEach(btn => {
+      btn.addEventListener('click', () => {
+        const kw = (btn as HTMLElement).dataset['keyword'] || '';
+        const isPending = (btn as HTMLElement).dataset['pending'] === 'true';
+        if (isPending) {
+          this.removePendingKeyword(kw);
+        } else {
+          this.handleRemoveKeyword(kw);
+        }
+      });
+    });
+  }
+
+  private escapeHtml(str: string): string {
+    return str.replace(/&/g, '&amp;').replace(/</g, '&lt;')
+              .replace(/>/g, '&gt;').replace(/"/g, '&quot;');
+  }
+}
+
+customElements.define('helium-godseye-app', HeliumGodsEyeApp);
