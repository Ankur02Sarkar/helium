+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/ui/webui/godseye/godseye_handler.h"
+
+#include <memory>
+#include <string>
+#include <vector>
+
+#include "base/functional/bind.h"
+#include "base/values.h"
+#include "chrome/browser/godseye/godseye_config.h"
+#include "chrome/browser/profiles/profile.h"
+#include "content/public/browser/web_ui.h"
+
+GodsEyeHandler::GodsEyeHandler(Profile* profile)
+    : profile_(profile),
+      config_(std::make_unique<godseye::GodsEyeConfig>(
+          profile->GetPrefs(), profile->GetPath())) {}
+
+GodsEyeHandler::~GodsEyeHandler() = default;
+
+void GodsEyeHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "getGodsEyeState",
+      base::BindRepeating(&GodsEyeHandler::HandleGetState,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "activateGodsEye",
+      base::BindRepeating(&GodsEyeHandler::HandleActivate,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "godsEyeAddUrl",
+      base::BindRepeating(&GodsEyeHandler::HandleAddUrl,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "godsEyeAddKeyword",
+      base::BindRepeating(&GodsEyeHandler::HandleAddKeyword,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "godsEyeRemoveUrl",
+      base::BindRepeating(&GodsEyeHandler::HandleRemoveUrl,
+                          base::Unretained(this)));
+  web_ui()->RegisterMessageCallback(
+      "godsEyeRemoveKeyword",
+      base::BindRepeating(&GodsEyeHandler::HandleRemoveKeyword,
+                          base::Unretained(this)));
+}
+
+void GodsEyeHandler::HandleGetState(const base::Value::List& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+
+  base::Value::Dict state;
+  state.Set("isEnabled", config_->IsEnabled());
+  state.Set("isLocked", config_->IsLocked());
+  state.Set("expirySeconds",
+            static_cast<double>(config_->GetExpirySeconds()));
+  state.Set("secondsRemaining",
+            static_cast<double>(config_->SecondsRemaining()));
+
+  base::Value::List url_list;
+  for (const auto& u : config_->GetBlockedUrls()) url_list.Append(u);
+  state.Set("blockedUrls", std::move(url_list));
+
+  base::Value::List kw_list;
+  for (const auto& k : config_->GetBlockedKeywords()) kw_list.Append(k);
+  state.Set("blockedKeywords", std::move(kw_list));
+
+  ResolveJavascriptCallback(base::Value(callback_id),
+                             base::Value(std::move(state)));
+}
+
+void GodsEyeHandler::HandleActivate(const base::Value::List& args) {
+  AllowJavascript();
+  // args: [callbackId, expiryUtcSeconds, urlsArray, keywordsArray]
+  if (args.size() < 4) return;
+  const std::string& callback_id = args[0].GetString();
+  int64_t expiry = static_cast<int64_t>(args[1].GetDouble());
+
+  std::vector<std::string> urls, keywords;
+  if (args[2].is_list()) {
+    for (const auto& v : args[2].GetList()) {
+      if (v.is_string()) urls.push_back(v.GetString());
+    }
+  }
+  if (args[3].is_list()) {
+    for (const auto& v : args[3].GetList()) {
+      if (v.is_string()) keywords.push_back(v.GetString());
+    }
+  }
+
+  config_->Activate(expiry, urls, keywords);
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleAddUrl(const base::Value::List& args) {
+  AllowJavascript();
+  if (args.size() < 2) return;
+  const std::string& callback_id = args[0].GetString();
+  const std::string& url = args[1].GetString();
+  config_->AddUrl(url);
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleAddKeyword(const base::Value::List& args) {
+  AllowJavascript();
+  if (args.size() < 2) return;
+  const std::string& callback_id = args[0].GetString();
+  const std::string& keyword = args[1].GetString();
+  config_->AddKeyword(keyword);
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(true));
+}
+
+void GodsEyeHandler::HandleRemoveUrl(const base::Value::List& args) {
+  AllowJavascript();
+  if (args.size() < 2) return;
+  const std::string& callback_id = args[0].GetString();
+  const std::string& url = args[1].GetString();
+  bool ok = config_->RemoveUrl(url);
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(ok));
+}
+
+void GodsEyeHandler::HandleRemoveKeyword(const base::Value::List& args) {
+  AllowJavascript();
+  if (args.size() < 2) return;
+  const std::string& callback_id = args[0].GetString();
+  const std::string& keyword = args[1].GetString();
+  bool ok = config_->RemoveKeyword(keyword);
+  ResolveJavascriptCallback(base::Value(callback_id), base::Value(ok));
+}
