+
+RestrictedPageHandler::RestrictedPageHandler(Profile* profile)
+    : profile_(profile) {}
+
+RestrictedPageHandler::~RestrictedPageHandler() = default;
+
+void RestrictedPageHandler::RegisterMessages() {
+  web_ui()->RegisterMessageCallback(
+      "getGodsEyeInfo",
+      base::BindRepeating(&RestrictedPageHandler::HandleGetGodsEyeInfo,
+                          base::Unretained(this)));
+}
+
+void RestrictedPageHandler::HandleGetGodsEyeInfo(
+    const base::Value::List& args) {
+  AllowJavascript();
+  const std::string& callback_id = args[0].GetString();
+
+  godseye::GodsEyeConfig config(profile_->GetPrefs(), profile_->GetPath());
+
+  int64_t secs = config.SecondsRemaining();
+  int64_t days = secs / 86400;
+  int64_t hours = (secs % 86400) / 3600;
+  int64_t minutes = (secs % 3600) / 60;
+
+  base::Value::Dict info;
+  info.Set("secondsRemaining", static_cast<double>(secs));
+  info.Set("daysRemaining", static_cast<double>(days));
+  info.Set("hoursRemaining", static_cast<double>(hours));
+  info.Set("minutesRemaining", static_cast<double>(minutes));
+
+  ResolveJavascriptCallback(base::Value(callback_id),
+                             base::Value(std::move(info)));
+}
