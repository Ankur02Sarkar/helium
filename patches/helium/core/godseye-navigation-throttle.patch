+// Copyright 2025 The Helium Authors
+// You can use, redistribute, and/or modify this source code under
+// the terms of the GPL-3.0 license that can be found in the LICENSE file.
+
+#include "chrome/browser/godseye/godseye_navigation_throttle.h"
+
+#include <memory>
+#include <string>
+#include <vector>
+
+#include "base/strings/string_util.h"
+#include "chrome/browser/godseye/godseye_config.h"
+#include "chrome/browser/profiles/profile.h"
+#include "chrome/common/webui_url_constants.h"
+#include "content/public/browser/browser_context.h"
+#include "content/public/browser/navigation_handle.h"
+#include "content/public/browser/web_contents.h"
+#include "net/base/url_util.h"
+#include "url/gurl.h"
+
+GodsEyeNavigationThrottle::GodsEyeNavigationThrottle(
+    content::NavigationThrottleRegistry& registry)
+    : content::NavigationThrottle(registry) {}
+
+GodsEyeNavigationThrottle::~GodsEyeNavigationThrottle() = default;
+
+const char* GodsEyeNavigationThrottle::GetNameForLogging() {
+  return "GodsEyeNavigationThrottle";
+}
+
+// static
+void GodsEyeNavigationThrottle::MaybeCreateAndAdd(
+    content::NavigationThrottleRegistry& registry) {
+  content::NavigationHandle& handle = registry.GetNavigationHandle();
+  if (!handle.IsInMainFrame()) return;
+
+  content::WebContents* wc = handle.GetWebContents();
+  if (!wc) return;
+
+  Profile* profile =
+      Profile::FromBrowserContext(wc->GetBrowserContext());
+  if (!profile || profile->IsOffTheRecord()) return;
+
+  godseye::GodsEyeConfig config(profile->GetPrefs(), profile->GetPath());
+  if (!config.IsEnabled()) return;
+
+  registry.AddThrottle(std::make_unique<GodsEyeNavigationThrottle>(registry));
+}
+
+// static
+bool GodsEyeNavigationThrottle::MatchesBlockedUrl(
+    const std::string& host,
+    const std::vector<std::string>& blocked_urls) {
+  std::string host_lower = base::ToLowerASCII(host);
+  for (const auto& blocked : blocked_urls) {
+    std::string blocked_lower = base::ToLowerASCII(blocked);
+    if (host_lower == blocked_lower) return true;
+    // Suffix match: "example.com" blocks "sub.example.com"
+    if (base::EndsWith(host_lower, "." + blocked_lower,
+                       base::CompareCase::INSENSITIVE_ASCII)) {
+      return true;
+    }
+  }
+  return false;
+}
+
+content::NavigationThrottle::ThrottleCheckResult
+GodsEyeNavigationThrottle::CheckUrl(const GURL& url) {
+  // Never block internal pages.
+  if (url.SchemeIs("chrome") || url.SchemeIs("helium") ||
+      url.SchemeIs("about") || url.SchemeIs("data") ||
+      url.SchemeIs("blob")) {
+    return PROCEED;
+  }
+
+  content::WebContents* wc = navigation_handle().GetWebContents();
+  if (!wc) return PROCEED;
+
+  Profile* profile =
+      Profile::FromBrowserContext(wc->GetBrowserContext());
+  if (!profile) return PROCEED;
+
+  godseye::GodsEyeConfig config(profile->GetPrefs(), profile->GetPath());
+  if (!config.IsEnabled()) return PROCEED;
+
+  // --- URL host check ---
+  std::string host = url.host();
+  std::vector<std::string> blocked_urls = config.GetBlockedUrls();
+  if (MatchesBlockedUrl(host, blocked_urls)) {
+    std::string redirect_url =
+        std::string(chrome::kHeliumRestrictedURL) +
+        "?type=url&value=" + net::EscapeQueryParamValue(host, true);
+    return ThrottleCheckResult(
+        CANCEL,
+        net::ERR_BLOCKED_BY_CLIENT,
+        std::string(),   // no error page HTML
+        GURL(redirect_url));
+  }
+
+  // --- Search query keyword check ---
+  // Inspect query params for common search engines (q=, query=, search_query=)
+  std::vector<std::string> keywords = config.GetBlockedKeywords();
+  if (!keywords.empty() && url.has_query()) {
+    std::string query_str;
+    // Check multiple common parameter names
+    static const char* const kQueryParams[] = {"q", "query", "search_query",
+                                               "p", "wd", "text"};
+    for (const char* param : kQueryParams) {
+      if (net::GetValueForKeyInQuery(url, param, &query_str)) break;
+    }
+    if (!query_str.empty()) {
+      std::string query_lower = base::ToLowerASCII(query_str);
+      for (const auto& kw : keywords) {
+        std::string kw_lower = base::ToLowerASCII(kw);
+        if (query_lower.find(kw_lower) != std::string::npos) {
+          std::string redirect_url =
+              std::string(chrome::kHeliumRestrictedURL) +
+              "?type=keyword&value=" +
+              net::EscapeQueryParamValue(kw, true);
+          return ThrottleCheckResult(
+              CANCEL,
+              net::ERR_BLOCKED_BY_CLIENT,
+              std::string(),
+              GURL(redirect_url));
+        }
+      }
+    }
+  }
+
+  return PROCEED;
+}
+
+content::NavigationThrottle::ThrottleCheckResult
+GodsEyeNavigationThrottle::WillStartRequest() {
+  return CheckUrl(navigation_handle().GetURL());
+}
+
+content::NavigationThrottle::ThrottleCheckResult
+GodsEyeNavigationThrottle::WillRedirectRequest() {
+  return CheckUrl(navigation_handle().GetURL());
+}
