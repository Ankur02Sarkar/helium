+#ifndef CHROME_BROWSER_GODSEYE_GODSEYE_NAVIGATION_THROTTLE_H_
+#define CHROME_BROWSER_GODSEYE_GODSEYE_NAVIGATION_THROTTLE_H_
+
+#include <memory>
+#include <string>
+
+#include "content/public/browser/navigation_throttle.h"
+
+namespace content {
+class NavigationHandle;
+}
+
+// Intercepts navigations and blocks URLs that match the God's Eye blocked list.
+// When a blocked URL is detected, the navigation is cancelled and the user is
+// redirected to chrome://restricted-page?type=url&value=<host>.
+//
+// Also checks search query parameters for blocked keywords.
+class GodsEyeNavigationThrottle : public content::NavigationThrottle {
+ public:
+  explicit GodsEyeNavigationThrottle(
+      content::NavigationHandle* navigation_handle);
+  ~GodsEyeNavigationThrottle() override;
+
+  // content::NavigationThrottle:
+  ThrottleCheckResult WillStartRequest() override;
+  ThrottleCheckResult WillRedirectRequest() override;
+  const char* GetNameForLogging() override;
+
+  // Factory: creates a throttle for the given handle if God's Eye is active.
+  // Returns nullptr if God's Eye is disabled or the profile is unavailable.
+  static std::unique_ptr<GodsEyeNavigationThrottle> MaybeCreate(
+      content::NavigationHandle* handle);
+
+ private:
+  // Core check logic. Returns a redirect ThrottleCheckResult if the URL is
+  // blocked, or PROCEED if it is allowed.
+  ThrottleCheckResult CheckUrl(const GURL& url);
+
+  // Returns true if |host| matches any entry in |blocked_urls|.
+  // Matching: exact hostname OR hostname suffix (e.g. "example.com" matches
+  // "sub.example.com" and "example.com").
+  static bool MatchesBlockedUrl(const std::string& host,
+                                 const std::vector<std::string>& blocked_urls);
+};
+
+#endif  // CHROME_BROWSER_GODSEYE_GODSEYE_NAVIGATION_THROTTLE_H_
